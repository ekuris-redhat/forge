                        "format": "table",
                        "rawSql": "SELECT toStartOfDay(timestamp) as time, countIf(metadata['project_id'] != '') as project_id, countIf(metadata['ticket_type'] != '') as ticket_type, countIf(metadata['workflow_step'] != '') as workflow_step, countIf(session_id != '') as session_id FROM default.traces FINAL WHERE $__timeFilter(timestamp) GROUP BY time ORDER BY time"
