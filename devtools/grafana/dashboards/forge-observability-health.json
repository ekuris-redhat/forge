                      "spec": {
                        "format": "table",
                        "rawSql": "SELECT metadata['project_id'] as project, max(timestamp) as latest_trace FROM default.traces FINAL WHERE metadata['project_id'] != '' GROUP BY project ORDER BY latest_trace DESC"
