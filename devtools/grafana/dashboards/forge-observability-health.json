                      "spec": {
                        "format": "table",
                        "rawSql": "SELECT count() as observations_without_trace FROM default.observations o FINAL LEFT JOIN default.traces t FINAL ON o.trace_id = t.id WHERE $__timeFilter(o.start_time) AND t.id IS NULL"
