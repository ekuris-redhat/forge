          "skipUrlSync": false,
          "query": {
            "kind": "DataQuery",
            "group": "grafana-clickhouse-datasource",
            "version": "v0",
            "datasource": {
              "name": "langfuse-clickhouse"
            },
            "spec": {
              "__legacyStringValue": "SELECT DISTINCT metadata['workflow_step'] as step FROM default.traces FINAL WHERE step != '' ORDER BY step"
            }
          },
          "regex": "",
          "sort": "alphabeticalAsc",
          "definition": "SELECT DISTINCT metadata['workflow_step'] as step FROM default.traces FINAL WHERE step != '' ORDER BY step",
